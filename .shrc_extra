# Useful aliases for faster typing.
alias la="ls -a"
alias ll="ls -al"

alias gl="git branch; echo; git status"

# Make man pages word wrap at 100 characters.
MANWIDTH=100
export MANWIDTH

# Set Vim as the program of choice for anything requiring an editor.
export VISUAL=vim
export EDITOR="$VISUAL"

source .shrc_pictures
